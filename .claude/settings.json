{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./apps/web/.env)",
      "Read(./apps/web/.env.local)",
      "Read(./apps/web/.env.*.local)",
      "Read(./**/*.pem)",
      "Read(./**/credentials*.json)"
    ]
  }
}
