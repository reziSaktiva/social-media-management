{
  "name": "@social/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "bunx prisma generate",
    "db:validate": "bunx prisma validate",
    "db:migrate": "bun --env-file=.env.local x prisma migrate dev",
    "db:deploy": "bun --env-file=.env.local x prisma migrate deploy",
    "postinstall": "bunx prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@social/shared": "workspace:*",
    "@supabase/supabase-js": "^2.110.7",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "^16.2.10",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
