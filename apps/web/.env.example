# ─────────────────────────────────────────────────────────────
# apps/web/.env.example — copy to .env.local (EM-D04)
# Never commit .env.local. Values below are placeholders only.
# Local DB: Supabase Cloud project `social-media-local` (EM-D02).
# ─────────────────────────────────────────────────────────────

# Database — Prisma 7 (DO-D04)
# DATABASE_URL = Supavisor pooled — runtime PrismaClient (@prisma/adapter-pg) + Better Auth
# DIRECT_URL   = direct / session — prisma migrate via apps/web/prisma.config.ts
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Supabase platform (Realtime + Storage only — DO-D02)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Browser (NEXT_PUBLIC_* only — EM-D05)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Better Auth (AS-D01, AS-D05)
BETTER_AUTH_SECRET="generate-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional locally; required when enabling Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Better Auth Dash — official hosted admin/monitoring dashboard (optional;
# plugin only activates when BETTER_AUTH_API_KEY is set)
BETTER_AUTH_API_KEY=""
# BETTER_AUTH_API_URL=""
# BETTER_AUTH_KV_URL=""

# Outstand integration
OUTSTAND_API_KEY="your-outstand-api-key"
OUTSTAND_WEBHOOK_SECRET="your-outstand-webhook-secret"

# Cron → web job trigger (X-Job-Secret)
JOB_SECRET="generate-a-long-random-job-secret"

# Optional — set to 1 to skip fail-fast env checks (tests / tooling only)
# SKIP_ENV_VALIDATION=1
